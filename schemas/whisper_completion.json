{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "whisper_completion",
  "title": "whisper_completion",
  "type": "object",
  "required": ["video_id", "status", "bucket", "output_path", "timestamp"],
  "properties": {
    "video_id": {
      "type": "string",
      "description": "Unique identifier for the video"
    },
    "status": {
      "type": "string",
      "enum": ["completed", "pending", "failed"],
      "description": "Processing status of the transcription job"
    },
    "bucket": {
      "type": "string",
      "description": "GCS bucket where the output is stored"
    },
    "output_path": {
      "type": "string",
      "description": "Path within the bucket to the transcription output file"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of when the result was recorded"
    }
  },
  "additionalProperties": false
}
