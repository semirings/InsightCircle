[Unit]
Description=InsightStore FastAPI microservice
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/insightcircle/insight_store
ExecStart=/opt/insightcircle/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8100
Restart=on-failure
RestartSec=5
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
