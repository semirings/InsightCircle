<?xml version="1.0" encoding="UTF-8"?>
<ecore:EPackage xmi:version="2.0" xmlns:xmi="http://www.omg.org/XMI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:ecore="http://www.eclipse.org/emf/2002/Ecore" name="d4MQuery" nsURI="http://fhir.genalytics.platform/d4m/D4MQuery"
    nsPrefix="d4MQuery">
  <eClassifiers xsi:type="ecore:EClass" name="D4MQuery">
    <eStructuralFeatures xsi:type="ecore:EReference" name="query" eType="#//QueryExpr"
        containment="true"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="QueryExpr">
    <eStructuralFeatures xsi:type="ecore:EReference" name="row" eType="#//AxisExpr"
        containment="true"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="col" eType="#//AxisExpr"
        containment="true"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="AxisExpr"/>
  <eClassifiers xsi:type="ecore:EClass" name="RowColWildcard" eSuperTypes="#//AxisExpr"/>
  <eClassifiers xsi:type="ecore:EClass" name="RangeExpr" eSuperTypes="#//AxisExpr">
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="from" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="to" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="ListExpr" eSuperTypes="#//AxisExpr">
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="values" unique="false"
        upperBound="-1" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="StartsWithExpr" eSuperTypes="#//AxisExpr">
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="prefix" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="RegexExpr" eSuperTypes="#//AxisExpr">
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="pattern" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="LiteralExpr" eSuperTypes="#//AxisExpr">
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="value" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
  </eClassifiers>
</ecore:EPackage>
