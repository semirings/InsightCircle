# --- PROTECT REMOTE WORK ---
# This prevents local (potentially older) notebooks from overwriting remote ones
- *.ipynb

# --- IGNORE LOCAL SYSTEM JUNK ---
- .DS_Store
- .git/
- .vscode/
- .idea/

# --- IGNORE ENVIRONMENTS & ARTIFACTS ---
# Do not sync local Julia registries or Python venvs
- /.julia/
- /venv/
- /node_modules/
- .env*

# --- IGNORE SCRIPTS & DOCS ---
- rsy.sh
- vm.sh
- /doc/

# --- ALLOW EVERYTHING ELSE ---
+ *
