# --- PROTECT REMOTE WORK ---
- *.ipynb

# --- IGNORE LOCAL SYSTEM JUNK ---
- .DS_Store
- .git/
- .vscode/
- .idea/

# --- FLUTTER / DART SPECIFIC (NEW) ---
# Never sync the build folder; it's platform-specific and huge
- /build/
# Internal Flutter cache and plugin links
- /.dart_tool/
- /.flutter-plugins
- /.flutter-plugins-dependencies
- /pubspec.lock
# If using FVM for version management
- /.fvm/flutter_sdk

# --- APPLE NATIVE ARTIFACTS (NEW) ---
# Do not sync generated native pods or workspace state
- /ios/Pods/
- /macos/Pods/
- /ios/.symlinks/
- /macos/.symlinks/
- *.xcworkspace
- DerivedData/

# --- ENVIRONMENTS & ARTIFACTS ---
- /.julia/
- /venv/
- /node_modules/
- .terraform/
# - .env*

# --- IGNORE SCRIPTS & DOCS ---
- rsy.sh
- vm.sh
- /doc/

# --- ALLOW EVERYTHING ELSE ---
+ *
